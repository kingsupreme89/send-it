rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /players/{playerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == playerId;

      // Profile owner can edit any of their own fields. A game-logging transaction
      // also touches OTHER participants' docs, but only their stats/badges/team-usage —
      // never their identity fields — so non-owner updates are scoped to those keys.
      allow update: if request.auth != null && (
        request.auth.uid == playerId ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['statsByMode', 'teamUsage', 'badges'])
      );
      allow delete: if false;
    }

    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        (request.auth.uid in request.resource.data.winnerIds ||
         request.auth.uid in request.resource.data.loserIds);
      // Any signed-in user can set/clear their OWN emoji reaction
      // (not anyone else's), but cannot touch the score/stats/participants.
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) &&
        request.resource.data.reactions.diff(
          ('reactions' in resource.data) ? resource.data.reactions : {}
        ).affectedKeys().hasOnly([request.auth.uid]);

      // A participant (or whoever logged it) can correct the result/stats after
      // the fact — winnerIds/loserIds/gameMode/loggedBy stay fixed so it can't be
      // turned into a different game.
      allow update: if request.auth != null &&
        (request.auth.uid in resource.data.winnerIds ||
         request.auth.uid in resource.data.loserIds ||
         request.auth.uid == resource.data.loggedBy) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'winnerTeam', 'loserTeam', 'winnerScore', 'loserScore',
          'scoreDiff', 'comebackDeficit', 'isBlowout', 'isComeback', 'stats',
          'clipUrl', 'photoUrl'
        ]);

      // A participant (or whoever logged it) can delete the game entirely.
      allow delete: if request.auth != null &&
        (request.auth.uid in resource.data.winnerIds ||
         request.auth.uid in resource.data.loserIds ||
         request.auth.uid == resource.data.loggedBy);
    }
  }
}
